/* pages/ai-chat/ai-chat.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.header {
  padding: 40rpx 30rpx 20rpx;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.input-area {
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
}

.chat-list {
  flex: 1;
  padding: 30rpx;
}

.chat-item {
  display: flex;
  margin-bottom: 40rpx;
}

.user {
  justify-content: flex-end;
}

.ai {
  justify-content: flex-start;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.user-avatar {
  background: #4CAF50;
  color: white;
  margin-left: 20rpx;
}

.ai-avatar {
  background: #2196F3;
  color: white;
  margin-right: 20rpx;
}

.message {
  max-width: 70%;
  padding: 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

.user-message {
  background: #4CAF50;
  color: white;
  border-top-right-radius: 8rpx;
}

.ai-message {
  background: white;
  color: #333;
  border-top-left-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  margin-top: 20rpx;
  color: white;
  font-size: 28rpx;
}