.container {
  padding: 0rpx;
}

.activity-item {
  display: flex;
  width: 100%;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  border-bottom: 1px solid #ebebeb;
  padding-bottom: 20rpx;
}

.activity-content {
  flex: 1; /* 占据所有剩余空间 */
  margin-right: 20rpx; /* 给右侧按钮留出间距，防止紧贴 */
}
.activity-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.activity-time {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.activity-enrollment {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 10rpx;
}

.activity-description {
  font-size: 24rpx;
  color: #333333;
  margin-top: 10rpx;
  white-space: pre-wrap; /* 自动换行 */
}

.signup-btn {
  background-color: #50c8ff;
  color: #ffffff;
  border: none;
  border-radius: 4rpx;
  padding: 20rpx 40rpx;
  font-size: 24rpx;
  margin: 0;
/* 2. 核心修改：自动填充左侧空白，将按钮顶到最右边 */
  margin-left: auto;
  flex-shrink: 0;
}